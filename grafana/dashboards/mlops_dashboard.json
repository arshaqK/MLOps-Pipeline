{
    "title": "MLOps Dashboard",
    "uid": "mlops-main",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "15s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "title": "Model Accuracy Over Time",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "model_accuracy",
                    "legendFormat": "Accuracy"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": 0
                            },
                            {
                                "color": "yellow",
                                "value": 0.75
                            },
                            {
                                "color": "green",
                                "value": 0.80
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 2,
            "title": "Records Processed Rate",
            "type": "timeseries",
            "gridPos": {
                "x": 12,
                "y": 0,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "rate(records_processed_total[1m])",
                    "legendFormat": "Records/sec"
                }
            ]
        },
        {
            "id": 3,
            "title": "Total Retrains",
            "type": "stat",
            "gridPos": {
                "x": 0,
                "y": 8,
                "w": 6,
                "h": 4
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "retrain_count_total",
                    "legendFormat": "Retrains"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "yellow",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 10
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 4,
            "title": "Distribution Drift Detected",
            "type": "stat",
            "gridPos": {
                "x": 6,
                "y": 8,
                "w": 6,
                "h": 4
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "distribution_drift_detected",
                    "legendFormat": "Drift"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "No Drift",
                                    "color": "green"
                                }
                            }
                        },
                        {
                            "type": "value",
                            "options": {
                                "1": {
                                    "text": "DRIFT!",
                                    "color": "red"
                                }
                            }
                        }
                    ],
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 5,
            "title": "Datalake Unavailable (503s)",
            "type": "stat",
            "gridPos": {
                "x": 12,
                "y": 8,
                "w": 6,
                "h": 4
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "datalake_unavailable_total",
                    "legendFormat": "503 Errors"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 6,
            "title": "Prediction Latency p95 (seconds)",
            "type": "timeseries",
            "gridPos": {
                "x": 18,
                "y": 8,
                "w": 6,
                "h": 4
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "histogram_quantile(0.95, rate(response_delay_seconds_bucket[5m]))",
                    "legendFormat": "p95 latency"
                }
            ]
        },
        {
            "id": 7,
            "title": "Schema Changes",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 12,
                "w": 12,
                "h": 6
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "feature_added_total",
                    "legendFormat": "Features Added"
                },
                {
                    "datasource": "Prometheus",
                    "expr": "feature_removed_total",
                    "legendFormat": "Features Removed"
                }
            ]
        },
        {
            "id": 8,
            "title": "Predict Requests Total",
            "type": "timeseries",
            "gridPos": {
                "x": 12,
                "y": 12,
                "w": 12,
                "h": 6
            },
            "targets": [
                {
                    "datasource": "Prometheus",
                    "expr": "rate(predict_requests_total[1m])",
                    "legendFormat": "Requests/sec"
                },
                {
                    "datasource": "Prometheus",
                    "expr": "rate(predict_errors_total[1m])",
                    "legendFormat": "Errors/sec"
                }
            ]
        }
    ]
}